## Local API proxy server (src/server.ts) config. Copy to .env and adjust.

# Port the local Oracle Room API proxy listens on.
PORT=4000

# Origin allowed to call the proxy (the Next.js frontend dev server).
FRONTEND_ORIGIN=http://localhost:3000

# TxODDS TxLINE host. Defaults to the devnet host, matching this repo's
# devnet Solana program (6pW64gN...). Only override if you've switched the
# whole stack (RPC, program ID, wallet) to mainnet.
# TXLINE_BASE_URL=https://txline-dev.txodds.com

# Optional: an already-activated API token (printed by `npx tsx src/main.ts`
# as "API Token: ..."). Set this to skip the on-chain subscribe+activate
# flow (and the SOL transaction fee it costs) on every server restart.
# TXLINE_API_TOKEN=txoracle_api_...
